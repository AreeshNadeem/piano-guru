#:kivy 2.3.1
MyScreenManager:
    HomeScreen:
        name: "home"
    NameScreen:
        name: "name"
    ModeSelectionScreen:
        name: "mode_selection"
    CasualModeScreen:
        name: "casual_mode"
    AnalysisScreen:
        name: "analysis"
    BeginnerSongScreen:
        name: "beginner_song"
    IntermediateSongScreen:
        name: "intermediate_song"
    AIModeSongScreen:
        name: "AI_song"
    AIvsSongScreen:
        name: "ai_vs_song"
    WaitingScreen:
        name: "waiting"
    ResultScreen:
        name: "result"
    HowToPlayScreen:
        name: "howToPlay"
    CreditsScreen:
        name: "credits"
    # ── New screens ───────────────────────────────────────────────────────────
    PredictModeScreen:
        name: "predict_mode"
    PredictResultScreen:
        name: "predict_result"
    MelodySearchScreen:
        name: "melody_search"
    FacialRecommendationScreen:
        name: "facial_recommendation"


# ─────────────────────────────────────────────────────────────────────────────
#  Reusable style rules
# ─────────────────────────────────────────────────────────────────────────────
<PinkButton@Button>:
    font_name: "MightySouly-lxggD.ttf"
    font_size: 22
    size_hint_y: None
    height: 60
    background_normal: ""
    background_color: 1, 0.7, 0.8, 1
    color: 0, 0, 0, 1

<BlackButton@Button>:
    font_name: "MightySouly-lxggD.ttf"
    font_size: 22
    size_hint_y: None
    height: 60
    background_normal: ""
    background_color: 0, 0, 0, 1
    color: 1, 1, 1, 1

<PinkCard@BoxLayout>:
    size_hint_y: None
    height: 80
    canvas.before:
        Color:
            rgba: 1, 0.7, 0.8, 1
        Rectangle:
            pos: self.pos
            size: self.size


# ─────────────────────────────────────────────────────────────────────────────
<HomeScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Piano Guru"
            font_size: 100
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 120

        BoxLayout:
            orientation: 'vertical'
            spacing: 25
            size_hint: None, None
            size: 300, self.minimum_height
            pos_hint: {"center_x": 0.5}

            PinkButton:
                text: "Start"
                on_release: root.start_game()

            PinkButton:
                text: "Credits"
                on_release: root.show_credits()

            PinkButton:
                text: "How To Play"
                on_release: root.show_how_to_play()

            PinkButton:
                text: "Quit"
                on_release: app.stop()

        Widget:
            size_hint_y: 1


# ─────────────────────────────────────────────────────────────────────────────
<NameScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Enter Your Name"
            font_size: 60
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 120

        BoxLayout:
            orientation: 'vertical'
            spacing: 25
            size_hint: None, None
            size: 300, self.minimum_height
            pos_hint: {"center_x": 0.5}

            TextInput:
                id: name_input
                multiline: False
                hint_text: "Your Name"
                font_name: "MightySouly-lxggD.ttf"
                font_size: 28
                size_hint_y: None
                height: 60
                background_normal: ""
                background_color: 1, 0.9, 0.95, 1
                foreground_color: 0, 0, 0, 1
                cursor_color: 0, 0, 0, 1

            PinkButton:
                text: "Continue"
                on_release: root.submit_name()

        Widget:
            size_hint_y: 1


# ─────────────────────────────────────────────────────────────────────────────
<ModeSelectionScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [50, 30]
        spacing: 0

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Select Mode"
            font_size: 80
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            BoxLayout:
                orientation: 'vertical'
                spacing: 18
                size_hint_y: None
                height: self.minimum_height
                padding: [80, 20, 80, 20]

                # ── Core modes ────────────────────────────────────────────────
                Label:
                    text: "Core Modes"
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 20
                    color: 0.5, 0.5, 0.5, 1
                    size_hint_y: None
                    height: 30
                    halign: "left"
                    text_size: self.size

                PinkButton:
                    text: "🎹  Casual  —  free play"
                    on_release: root.select_mode('casual')

                PinkButton:
                    text: "🌱  Beginner  —  guided melodies"
                    on_release: root.select_mode('beginner')

                PinkButton:
                    text: "⚡  Speed Mode  —  beat the clock"
                    on_release: root.select_mode('intermediate')

                PinkButton:
                    text: "🤖  AI Mode  —  watch then play"
                    on_release: root.select_mode('AI')

                PinkButton:
                    text: "🏆  AI vs You  —  race the AI"
                    on_release: root.select_mode('ai_vs')

                # ── Smart features ────────────────────────────────────────────
                Label:
                    text: "Smart Features"
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 20
                    color: 0.5, 0.5, 0.5, 1
                    size_hint_y: None
                    height: 30
                    halign: "left"
                    text_size: self.size

                PinkButton:
                    text: "🎤  Hum a Melody  —  ESP32 mic"
                    on_release: root.select_mode('humming')

                PinkButton:
                    text: "😊  Mood Recommend  —  webcam"
                    on_release: root.select_mode('emotion')

                PinkButton:
                    text: "🔍  Predict Song  —  play & match"
                    on_release: root.select_mode('predict')

                PinkButton:
                    text: "🗂️  Search Melodies  —  find & play"
                    on_release: root.select_mode('search')

                # ── Stats / back ──────────────────────────────────────────────
                Label:
                    text: "Stats"
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 20
                    color: 0.5, 0.5, 0.5, 1
                    size_hint_y: None
                    height: 30
                    halign: "left"
                    text_size: self.size

                PinkButton:
                    text: "📊  Analyse My Performance"
                    on_release: root.select_mode('analysis')

                BlackButton:
                    text: "< Back to Main Menu"
                    on_release: root.go_back()

        Widget:
            size_hint_y: None
            height: 20


# ─────────────────────────────────────────────────────────────────────────────
<AnalysisScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Performance Analysis"
            font_size: 80
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            BoxLayout:
                orientation: 'vertical'
                spacing: 20
                size_hint_y: None
                height: self.minimum_height
                padding: [40, 10]

                PinkCard:
                    Label:
                        text: "🏆 Best Song:"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: root.best_song if root.best_song else "N/A"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "📉 Worst Song:"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: root.worst_song if root.worst_song else "N/A"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "🎯 Average Accuracy:"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: f"{root.average_accuracy:.1f}%" if root.average_accuracy else "0.0%"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "⚠️ Average Mistakes:"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: f"{root.average_mistakes:.1f}" if root.average_mistakes else "0"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "🎵 Total Songs:"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: str(root.total_songs) if root.total_songs else "0"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "✅ Correct Notes:"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: str(root.total_correct) if root.total_correct else "0"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "❌ Total Mistakes:"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                    Label:
                        text: str(root.total_mistakes) if root.total_mistakes else "0"
                        font_size: 24
                        font_name: "MightySouly-lxggD.ttf"
                        color: 0, 0, 0, 1
                        size_hint_x: 0.5
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size

        BoxLayout:
            orientation: 'horizontal'
            spacing: 20
            size_hint: None, None
            size: 500, 60
            pos_hint: {"center_x": 0.5}

            BlackButton:
                text: "< Back"
                on_release: root.go_back()

            PinkButton:
                text: "Reset Stats"
                on_release: root.reset_stats()

        Widget:
            size_hint_y: 0.2


# ─────────────────────────────────────────────────────────────────────────────
<CasualModeScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Casual Mode"
            font_size: 80
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        BoxLayout:
            orientation: 'vertical'
            padding: 40
            spacing: 30
            size_hint: None, None
            size: 600, 350
            pos_hint: {"center_x": 0.5}

            canvas.before:
                Color:
                    rgba: 1, 0.7, 0.8, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "Free Play Mode"
                font_size: 40
                font_name: "MightySouly-lxggD.ttf"
                color: 0, 0, 0, 1
                size_hint_y: None
                height: 60

            Label:
                text: root.status_text
                font_size: 28
                font_name: "MightySouly-lxggD.ttf"
                color: 0, 0, 0, 1
                size_hint_y: None
                height: 60
                halign: "center"
                valign: "middle"
                text_size: self.size

            Label:
                text: "No scoring, no mistakes tracked.\nJust have fun and play freely! 🎵"
                font_size: 24
                font_name: "MightySouly-lxggD.ttf"
                color: 0, 0, 0, 1
                size_hint_y: None
                height: 80
                halign: "center"
                valign: "middle"
                text_size: self.size

        Widget:
            size_hint_y: 1

        BlackButton:
            text: "< Back to Menu"
            size_hint: None, None
            size: 300, 60
            pos_hint: {"center_x": 0.5}
            on_release: root.go_back()

        Widget:
            size_hint_y: 0.2


# ─────────────────────────────────────────────────────────────────────────────
<BeginnerSongScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Beginner Mode"
            font_size: 80
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        Label:
            text: "Select a Song"
            font_size: 40
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 60

        BoxLayout:
            orientation: 'vertical'
            spacing: 25
            size_hint: None, None
            size: 400, self.minimum_height
            pos_hint: {"center_x": 0.5}

            PinkButton:
                text: "Twinkle Twinkle"
                on_release: root.select_song('twinkle')

            PinkButton:
                text: "Mary Had a Little Lamb"
                on_release: root.select_song('mary')

            PinkButton:
                text: "Jingle Bells"
                on_release: root.select_song('jingle')

            PinkButton:
                text: "🎲  Random"
                on_release: root.select_song('random')

            PinkButton:
                text: "🗂️  Search Saved Melodies"
                on_release: root.manager.current = 'melody_search'

            BlackButton:
                text: "< Back"
                on_release: root.go_back()

        Widget:
            size_hint_y: 1


# ─────────────────────────────────────────────────────────────────────────────
