                        text: "😊 Mood Recommend: Look at the camera — we pick songs based on your emotion"
                        font_name: "MightySouly-lxggD.ttf"
                        font_size: 20
                        color: 0, 0, 0, 1
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                PinkCard:
