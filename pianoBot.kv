# ── Melody Search ─────────────────────────────────────────────────────────────
<MelodySearchScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 20

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "🗂️  Search Melodies"
            font_size: 70
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        # Search bar row
        BoxLayout:
            orientation: 'horizontal'
            spacing: 15
            size_hint: None, None
            size: 700, 60
            pos_hint: {"center_x": 0.5}

            TextInput:
                id: search_input
                multiline: False
                hint_text: "Type a melody name..."
                font_name: "MightySouly-lxggD.ttf"
                font_size: 22
                background_normal: ""
                background_color: 1, 0.9, 0.95, 1
                foreground_color: 0, 0, 0, 1
                cursor_color: 0, 0, 0, 1
                size_hint_x: 0.75

            PinkButton:
                text: "Search"
                size_hint_x: 0.25
                on_release: root.do_search()

        # Status label
        Label:
            text: root.status_text
            font_name: "MightySouly-lxggD.ttf"
            font_size: 20
            color: 0.4, 0.4, 0.4, 1
            size_hint_y: None
            height: 35
            halign: "center"
            text_size: self.size

        # Results list
        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            BoxLayout:
                id: results_container
                orientation: 'vertical'
                spacing: 12
                size_hint_y: None
                height: self.minimum_height
                padding: [60, 5, 60, 10]

        Widget:
            size_hint_y: 1

        BlackButton:
            text: "< Back"
            size_hint: None, None
            size: 300, 60
            pos_hint: {"center_x": 0.5}
            on_release: root.go_back()

        Widget:
            size_hint_y: None
            height: 20


# ── Predict Mode ──────────────────────────────────────────────────────────────
<PredictModeScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 30

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "🔍  Predict Song"
            font_size: 70
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        # Info card
        BoxLayout:
            orientation: 'vertical'
            padding: 30
            spacing: 15
            size_hint: None, None
            size: 600, 220
            pos_hint: {"center_x": 0.5}

            canvas.before:
                Color:
                    rgba: 1, 0.7, 0.8, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: root.status_text
                font_name: "MightySouly-lxggD.ttf"
                font_size: 22
                color: 0, 0, 0, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
                size_hint_y: None
                height: 60

            Label:
                text: "Notes captured: " + (root.captured_notes if root.captured_notes else "none yet")
                font_name: "MightySouly-lxggD.ttf"
                font_size: 20
                color: 0, 0, 0, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
                size_hint_y: None
                height: 50

            Label:
                text: "🎹  Use the piano keys to play. We'll match your melody."
                font_name: "MightySouly-lxggD.ttf"
                font_size: 18
                color: 0.3, 0.3, 0.3, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
                size_hint_y: None
                height: 50

        Widget:
            size_hint_y: 1

        # Action buttons
        BoxLayout:
            orientation: 'horizontal'
            spacing: 20
            size_hint: None, None
            size: 700, 60
            pos_hint: {"center_x": 0.5}

            PinkButton:
                text: "▶  Start Recording"
                on_release: root.start_recording()

            PinkButton:
                text: "⏹  Stop & Match"
                on_release: root.stop_recording()

        BoxLayout:
            orientation: 'horizontal'
            spacing: 20
            size_hint: None, None
            size: 700, 60
            pos_hint: {"center_x": 0.5}

            PinkButton:
                text: "💾  Save as Custom"
                on_release: root.save_as_custom()

            PinkButton:
                text: "📚  View Library"
                on_release: root.show_library_popup()

        BlackButton:
            text: "< Back"
            size_hint: None, None
            size: 300, 60
            pos_hint: {"center_x": 0.5}
            on_release: root.go_back()

        Widget:
            size_hint_y: None
            height: 20


# ── Predict Result ────────────────────────────────────────────────────────────
<PredictResultScreen>:
