            height: 95

        # Status card
        BoxLayout:
            orientation: 'vertical'
            padding: 25
            spacing: 10
            size_hint: None, None
            size: 620, 150
            pos_hint: {"center_x": 0.5}
            canvas.before:
                Color:
                    rgba: 1, 0.7, 0.8, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

