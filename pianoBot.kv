                        color: 0, 0, 0, 1
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                BlackButton:
                    text: "< Back to Main Menu"
                    on_release: root.go_back()

        Widget:
            size_hint_y: 0.1


