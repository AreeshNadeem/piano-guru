# ── Facial / Emotion Recommendation ──────────────────────────────────────────
<FacialRecommendationScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 25

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
