    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Speed Mode"
            font_size: 80
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        Label:
            text: "Select a Song (Time Limited)"
            font_size: 30
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 60

        BoxLayout:
            orientation: 'vertical'
            spacing: 25
            size_hint: None, None
            size: 400, self.minimum_height
            pos_hint: {"center_x": 0.5}

            PinkButton:
                text: "Twinkle Twinkle"
                on_release: root.select_song('twinkle')

            PinkButton:
                text: "Mary Had a Little Lamb"
                on_release: root.select_song('mary')

            PinkButton:
                text: "Jingle Bells"
                on_release: root.select_song('jingle')

            PinkButton:
                text: "🎲  Random"
                on_release: root.select_song('random')

            PinkButton:
                text: "🗂️  Search Saved Melodies"
                on_release: root.manager.current = 'melody_search'

            BlackButton:
                text: "< Back"
                on_release: root.go_back()

        Widget:
            size_hint_y: 1


# ─────────────────────────────────────────────────────────────────────────────
<AIModeSongScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
