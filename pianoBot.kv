                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "⚡ Speed Mode: Complete songs within time limit"
                        font_name: "MightySouly-lxggD.ttf"
                        font_size: 20
                        color: 0, 0, 0, 1
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "🤖 AI Mode: AI plays first, then you follow"
                        font_name: "MightySouly-lxggD.ttf"
                        font_size: 20
                        color: 0, 0, 0, 1
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "🏆 AI vs You: Compete for fastest time"
                        font_name: "MightySouly-lxggD.ttf"
                        font_size: 20
                        color: 0, 0, 0, 1
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                PinkCard:
                    Label:
                        text: "🎤 Hum a Melody: Hum into the mic — ESP32 detects your tune and plays it back"
                        font_name: "MightySouly-lxggD.ttf"
                        font_size: 20
                        color: 0, 0, 0, 1
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                PinkCard:
