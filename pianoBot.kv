        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            BoxLayout:
                orientation: 'vertical'
                spacing: 25
                size_hint: None, None
                size: 600, self.minimum_height
                pos_hint: {"center_x": 0.5}
                padding: [0, 0, 0, 20]

                PinkCard:
                    Label:
                        text: "🌱 Beginner: Play melodies and see your results"
                        font_name: "MightySouly-lxggD.ttf"
