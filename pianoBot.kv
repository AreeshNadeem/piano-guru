        Label:
            text: "AI Mode"
            font_size: 80
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        Label:
            text: "AI plays first, then you"
            font_size: 30
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 60

        BoxLayout:
            orientation: 'vertical'
            spacing: 25
            size_hint: None, None
            size: 400, self.minimum_height
            pos_hint: {"center_x": 0.5}

            PinkButton:
                text: "Twinkle Twinkle"
                on_release: root.select_song('twinkle')

            PinkButton:
                text: "Mary Had a Little Lamb"
                on_release: root.select_song('mary')

            PinkButton:
                text: "Jingle Bells"
                on_release: root.select_song('jingle')

            PinkButton:
                text: "🎲  Random"
                on_release: root.select_song('random')

            PinkButton:
                text: "🗂️  Search Saved Melodies"
                on_release: root.manager.current = 'melody_search'

            BlackButton:
                text: "< Back"
                on_release: root.go_back()

        Widget:
            size_hint_y: 1


# ─────────────────────────────────────────────────────────────────────────────
<AIvsSongScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "AI vs You"
            font_size: 80
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 100

        Label:
            text: "Compete with AI"
            font_size: 30
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 60

        BoxLayout:
            orientation: 'vertical'
            spacing: 25
            size_hint: None, None
            size: 400, self.minimum_height
            pos_hint: {"center_x": 0.5}

            PinkButton:
                text: "Twinkle Twinkle"
                on_release: root.select_song('twinkle')

            PinkButton:
                text: "Mary Had a Little Lamb"
                on_release: root.select_song('mary')

            PinkButton:
                text: "Jingle Bells"
                on_release: root.select_song('jingle')

            PinkButton:
                text: "🎲  Random"
                on_release: root.select_song('random')

            BlackButton:
                text: "< Back"
                on_release: root.go_back()

        Widget:
            size_hint_y: 1


# ─────────────────────────────────────────────────────────────────────────────
<WaitingScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Playing..."
            font_size: 100
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 120

        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            size: 500, 300
            pos_hint: {"center_x": 0.5}
            spacing: 20
            padding: 20

            canvas.before:
                Color:
                    rgba: 1, 0.7, 0.8, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: root.melody_text
                font_name: "MightySouly-lxggD.ttf"
                font_size: 28
                color: 0, 0, 0, 1
                halign: "center"
                valign: "middle"
                text_size: self.size

            Label:
                text: root.status_text
                font_name: "MightySouly-lxggD.ttf"
                font_size: 22
                color: 0, 0, 0, 1
                halign: "center"
                valign: "middle"
                text_size: self.size

            Label:
                text: root.timer_text if root.show_timer else ""
                font_name: "MightySouly-lxggD.ttf"
                font_size: 26
                color: 0, 0, 0, 1
                halign: "center"
                valign: "middle"
                text_size: self.size

        BlackButton:
            text: "Cancel"
            size_hint: None, None
            size: 300, 60
            pos_hint: {"center_x": 0.5}
            on_release: root.cancel()

        Widget:
            size_hint_y: 1


# ─────────────────────────────────────────────────────────────────────────────
<ResultScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: root.result_text
            font_size: 80
            font_name: "MightySouly-lxggD.ttf"
            color: 0, 0, 0, 1
            size_hint_y: None
            height: 120

        BoxLayout:
            orientation: 'vertical'
            spacing: 25
            size_hint: None, None
            size: 500, self.minimum_height
            pos_hint: {"center_x": 0.5}

            # AI vs comparison
            BoxLayout:
                size_hint_y: None
                height: 80 if root.show_comparison else 0
                opacity: 1 if root.show_comparison else 0
                canvas.before:
                    Color:
                        rgba: 1, 0.7, 0.8, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: root.user_time_text
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 28
                    color: 0, 0, 0, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: 80 if root.show_comparison else 0
                opacity: 1 if root.show_comparison else 0
                canvas.before:
                    Color:
                        rgba: 1, 0.7, 0.8, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: root.ai_time_text
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 28
                    color: 0, 0, 0, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: 80 if root.show_comparison else 0
                opacity: 1 if root.show_comparison else 0
                canvas.before:
                    Color:
                        rgba: 1, 0.7, 0.8, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: root.winner_text
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 28
                    color: 0, 0, 0, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.size

            # Normal results
            BoxLayout:
                size_hint_y: None
                height: 0 if root.show_comparison else 80
                opacity: 0 if root.show_comparison else 1
                canvas.before:
                    Color:
                        rgba: 1, 0.7, 0.8, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "Correctness: " + str(root.percentage) + "%"
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 28
                    color: 0, 0, 0, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: 0 if root.show_comparison else 80
                opacity: 0 if root.show_comparison else 1
                canvas.before:
                    Color:
                        rgba: 1, 0.7, 0.8, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: "Mistakes: " + str(root.errors)
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 28
                    color: 0, 0, 0, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: 80 if root.rating else 0
                opacity: 1 if root.rating else 0
                canvas.before:
                    Color:
                        rgba: 1, 0.7, 0.8, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: root.rating
                    font_name: "MightySouly-lxggD.ttf"
                    font_size: 28
                    color: 0, 0, 0, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.size

            PinkButton:
                text: "Play Again"
                on_release: root.play_again()

            BlackButton:
                text: "< Back to Main Menu"
                on_release: root.go_home()

        Widget:
            size_hint_y: 1


# ─────────────────────────────────────────────────────────────────────────────
<HowToPlayScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 40

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
